          },
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": {
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "pageSize",
            "required": false,
            "in": "query",
            "schema": {
              "example": 12,
              "type": "number"
            }
          },
          {
            "name": "sort",
            "required": false,
            "in": "query",
            "schema": {
              "example": "newest",
              "type": "string",
              "enum": [
                "newest",
                "price-asc",
                "price-desc",
                "rating",
                "best-seller"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
