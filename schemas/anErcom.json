  "info": {
    "title": "An-ercom API",
    "description": "API cho hệ thống thương mại điện tử An-ercom (FE + Admin)",
    "version": "2.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "Địa chỉ email"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "description": "Mật khẩu (tối thiểu 6 ký tự)"
          },
          "fullName": {
            "type": "string",
            "example": "Nguyễn Văn A",
            "description": "Họ và tên đầy đủ"
          }
        },
        "required": [
          "email",
          "password",
          "fullName"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Địa chỉ email đăng nhập",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "Mật khẩu đăng nhập",
            "example": "password123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
